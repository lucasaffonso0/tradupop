{
  "manifest_version": 3,
  "name": "TradupPop",
  "version": "1.0.0",
  "description": "Selecione qualquer palavra na página e receba a tradução instantaneamente com áudio, dicionário e exemplos de uso.",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api.mymemory.translated.net/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TradupPop",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["ui-strings.js", "background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tradupop@lucasaffonso0.github.io",
      "strict_min_version": "128.0"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+Y" }
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["ui-strings.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
